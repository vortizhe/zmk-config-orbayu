#include <dt-bindings/zmk/matrix_transform.h>

#include "orbayu-layouts.dtsi"

/ {
    chosen {
        zmk,physical-layout = &default_layout;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <6>;
        rows = <4>;

        /*
         * Left half: 6 cols x 4 rows = 23 keys
         * col5 has only 3 keys (rows 0-2), RC(3,5) does not exist.
         *
         * col:  0         1         2         3         4         5
         *       D10(P1.15) D9(P1.14) D18(P1.05) D8(P1.13) D17(P1.03) D7(P1.12)
         * row0: D2(P0.28)
         * row1: D3(P0.29)
         * row2: D4(P0.04)
         * row3: D5(P0.05)  [col5 absent in row3]
         */
        map = <
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4)
        >;
    };

    encoder_0: encoder_0 {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* A = D0 (P0.02) */
        b-gpios = <&gpio0 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* B = D1 (P0.03) */
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_0>;
        triggers-per-rotation = <20>;
    };
};
