#include <dt-bindings/zmk/matrix_transform.h>

#include "orbayu-layouts.dtsi"

/ {
    chosen {
        zmk,physical-layout = &default_layout;
    };

    default_transform: default_transform {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;

        /*
         * Full keyboard: left (cols 0-5) + right (cols 6-11, col-offset=6)
         *
         * LEFT — 23 keys
         *  col:   0       1       2       3       4       5
         *         D10     D9      D18     D8      D17     D7
         * row0:  P1.15  P1.14  P1.05  P1.13  P1.03  P1.12
         * row1:  "      "      "      "      "      "
         * row2:  "      "      "      "      "      "
         * row3:  "      "      "      "      "      [absent]
         * rows: D2(P0.28) D3(P0.29) D4(P0.04) D5(P0.05)
         *
         * RIGHT — 21 keys (col-offset=6 → physical cols 0-5 = transform cols 6-11)
         *  col:   6       7       8       9       10      11
         *         COL0    COL1    COL2    COL3    COL4    COL5
         *         P1.11  P0.31  P0.05  P0.10  P0.04  P0.09
         * row0:  [absent]  ✓      ✓      ✓      ✓      ✓
         * row1:   ✓       ✓      ✓      ✓      ✓      ✓
         * row2:   ✓       ✓      ✓      ✓      ✓      ✓
         * row3:   ✓       ✓    [absent][absent]  ✓      ✓
         * rows: D0(P0.02) D1(P0.03) D3(P0.29) D2(P0.28)
         */
        map = <
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)           RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)  RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)  RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)            RC(3,6)  RC(3,7)                     RC(3,10) RC(3,11)
        >;
    };

    encoder_0: encoder_0 {
        compatible = "alps,ec11";
        a-gpios = <&gpio0 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* A = D0 (P0.02) */
        b-gpios = <&gpio0 3 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   /* B = D1 (P0.03) */
        steps = <80>;
        status = "disabled";
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&encoder_0>;
        triggers-per-rotation = <20>;
    };
};
